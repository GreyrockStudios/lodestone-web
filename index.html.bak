<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lodestone — Your AI, Always On</title>
    <meta name="description" content="Private, local AI agent that remembers everything and acts on your behalf. Runs on your machine, data stays yours." />
    <meta name="theme-color" content="#0a0a0a" />
    <meta property="og:title" content="Lodestone — Your AI, Always On" />
    <meta property="og:description" content="Private, local AI agent that remembers everything and acts on your behalf. Runs on your machine, data stays yours." />
    <meta property="og:image" content="https://heylodestone.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://heylodestone.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lodestone" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Lodestone — Your AI, Always On" />
    <meta name="twitter:description" content="Private, local AI agent that remembers everything and acts on your behalf. Runs on your machine, data stays yours." />
    <meta name="twitter:image" content="https://heylodestone.com/og-image.png" />
    <link rel="canonical" href="https://heylodestone.com/" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Lodestone",
      "description": "Private, local AI agent that remembers everything and acts on your behalf. Runs on your machine, data stays yours.",
      "url": "https://heylodestone.com",
      "applicationCategory": "AI Assistant",
      "operatingSystem": ["macOS", "Windows", "Linux"],
      "offers": [
        {
          "@type": "Offer",
          "name": "Free",
          "price": "0",
          "priceCurrency": "USD",
          "description": "Local agent with core features"
        },
        {
          "@type": "Offer",
          "name": "Desktop",
          "price": "9.99",
          "priceCurrency": "USD",
          "description": "Your AI, always on, always local"
        },
        {
          "@type": "Offer",
          "name": "Pro",
          "price": "19.99",
          "priceCurrency": "USD",
          "description": "Multi-provider power user"
        }
      ]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Greyrock Studio",
      "url": "https://heylodestone.com",
      "logo": "https://heylodestone.com/icon.png"
    }
    </script>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/main.tsx"></script>
  </body>
</html>
