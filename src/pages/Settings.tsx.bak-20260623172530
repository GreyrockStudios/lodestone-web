}
const PROFESSION_CARDS = [
  { id: 'assistant', emoji: '🤝', label: 'Assistant', desc: 'General purpose helper' },
  { id: 'developer', emoji: '💻', label: 'Developer', desc: 'Code & technical help' },
  { id: 'writer', emoji: '✍️', label: 'Writer', desc: 'Content & copy' },
