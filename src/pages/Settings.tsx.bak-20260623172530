import { useState, useEffect, useCallback } from 'react'
import { useNavigate } from 'react-router-dom'
import { useAuth } from '../hooks/useAuth'
import { Eye, EyeOff, Key, ExternalLink, CreditCard, HardDrive, AlertTriangle, Plus, Trash2, X, ChevronLeft, Shield, Clock, Cpu, FileText, Bell } from 'lucide-react'
